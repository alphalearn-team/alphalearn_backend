# Mode-specific env template.
# Copy to .env.local (or .env.production) and fill values.
# Shared values belong in .env.shared (from .env.shared.example).

# Database
DB_URL=jdbc:postgresql://127.0.0.1:54322/postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Supabase Auth (JWKS for JWT verification)
SUPABASE_JWT_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Optional Supabase client values (useful for frontend/tools)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App / CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000
