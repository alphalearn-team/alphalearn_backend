# Database
DB_URL=jdbc:postgresql://127.0.0.1:54322/postgres
DB_USER=postgres
DB_PASSWORD=postgres

# Supabase Auth (JWKS for JWT verification)
SUPABASE_JWT_JWKS_URL=http://127.0.0.1:54321/auth/v1/.well-known/jwks.json

# Optional Supabase client values (useful for frontend/tools)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App / CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Weekly quest
WEEKLY_QUEST_ZONE_ID=Asia/Singapore
WEEKLY_QUEST_FALLBACK_CONCEPT_PUBLIC_ID=00000000-0000-0000-0000-000000000000
WEEKLY_QUEST_FALLBACK_TEMPLATE_PUBLIC_ID=00000000-0000-0000-0000-000000000000
WEEKLY_QUEST_REMINDER_DAILY_HOUR=12
WEEKLY_QUEST_REMINDER_DAILY_MINUTE=0
WEEKLY_QUEST_ACTIVATION_POLL_MINUTES=10

# Cloudflare R2 (optional)
CLOUDFLARE_R2_ENABLED=false
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_PUBLIC_BASE_URL=
CLOUDFLARE_R2_PRESIGN_EXPIRY_MINUTES=15
CLOUDFLARE_R2_MAX_UPLOAD_SIZE_BYTES=52428800
