# CI-hosted database settings for ci_check.sh / ci_check.cmd.
# Copy this file to .env.ci and fill in your values.

CI_DB_URL_JDBC=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
CI_DB_USER=postgres
CI_DB_PASSWORD=
CI_SUPABASE_JWKS_URL=https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
